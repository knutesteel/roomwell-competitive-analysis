{
  "name": "roomwell-app",
  "version": "0.0.0",
  "private": true,
  "description": "Roomwell — lightweight scheduling and client management for solo wellness practitioners.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:migrate": "pnpm --filter @roomwell/db migrate",
    "db:generate": "pnpm --filter @roomwell/db generate",
    "db:studio": "pnpm --filter @roomwell/db studio",
    "db:seed": "pnpm --filter @roomwell/db seed",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "prettier": "^3.3.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.1.0",
    "typescript": "^5.5.0"
  }
}

# =============================================================================
# Roomwell environment variables
#
# Copy this file to .env.local for local development.
# In Vercel + GitHub Actions, these live in the secrets manager — never commit.
# =============================================================================

# ---- App ---------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ---- Supabase (Postgres + Auth + Storage) -----------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=               # Server-only; NEVER prefix NEXT_PUBLIC_
DATABASE_URL=                            # Direct Postgres connection for Drizzle migrations

# ---- AWS KMS (PHI envelope encryption) --------------------------------------
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
KMS_KEK_ID=                              # ARN of the master KEK

# ---- Postmark (transactional email) -----------------------------------------
POSTMARK_SERVER_TOKEN=
POSTMARK_FROM_EMAIL=hello@roomwell.com
POSTMARK_WEBHOOK_SECRET=

# ---- Inngest (background jobs) ----------------------------------------------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ---- Upstash Redis (rate limiting) ------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---- Google Calendar OAuth --------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/webhooks/google/callback

# ---- Cloudflare Turnstile (booking-page abuse) ------------------------------
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Sentry (errors) --------------------------------------------------------
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                       # For uploading source maps in CI

# ---- Axiom (logs) -----------------------------------------------------------
AXIOM_TOKEN=
AXIOM_DATASET=roomwell-app

# ---- Stripe (M6: practitioner subscription billing) -------------------------
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ---- Token signing secrets --------------------------------------------------
# 32+ byte random hex for HMAC on tokenized public links (intake, counter, review)
TOKEN_SIGNING_SECRET=
ICAL_FEED_SIGNING_SECRET=

# ---- Misc -------------------------------------------------------------------
LOG_LEVEL=info
